# TLS: use `tls internal` for local self-signed certs, or set your real hostname + email for ACME.
:80 {
	reverse_proxy api:8000
}

:443 {
	tls internal
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
	# Deep health probe hits DB+Redis — keep off the public edge.
	@deep path /health/deep
	respond @deep 403
	reverse_proxy api:8000
}
