# Copy to .env.production and fill in secrets (never commit .env.production).
#
# Database URL is built in docker-compose.production.yml from POSTGRES_*; override here only if needed.
# DATABASE_URL=postgresql+asyncpg://openpms:CHANGE_ME@db:5432/openpms

# Prefer RS256 in production (issue with private key; verify with public key only on read replicas).
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY_PEM=...
# JWT_PUBLIC_KEY_PEM=...
JWT_SECRET=generate-at-least-32-random-bytes
CORS_ORIGINS=https://app.yourdomain.com

# Celery (docker-compose.production.yml sets redis://redis:6379/0 for api + worker; override if needed)
# CELERY_BROKER_URL=redis://redis:6379/0

# Compose + Caddy
DOMAIN=api.yourdomain.com
ACME_EMAIL=ops@yourdomain.com
POSTGRES_USER=openpms
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=openpms

# Optional: S3-compatible backup target (see scripts/backup_pg_to_s3.sh)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=sgp1
# S3_BUCKET=openpms-backups
# AWS_ENDPOINT_URL=https://sgp1.digitaloceanspaces.com
