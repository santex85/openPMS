# Staging environment template — copy to .env.staging (never commit real secrets).
# Use with: docker compose -f docker-compose.production.yml --env-file .env.staging up -d
# See docs/deploy.md

APP_ENV=staging
LOG_FORMAT=json

# Staging SPA + API hostnames (adjust to your DNS)
DOMAIN=staging.example.com
ACME_EMAIL=ops@example.com
CORS_ORIGINS=https://staging.example.com,https://app.staging.example.com

# Strong secrets — generate via scripts/generate-secrets.sh
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET_MIN_32_CHARS
WEBHOOK_SECRET_FERNET_KEY=REPLACE_WITH_FERNET_KEY

# Stripe **test mode** keys only on staging
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_CLIENT_ID=ca_...
# STRIPE_REDIRECT_URI=https://staging.example.com/stripe/oauth/callback
# STRIPE_CONNECT_SUCCESS_URL=https://app.staging.example.com/settings

# Channex staging property / test credentials
# CHANNEX_WEBHOOK_URL=https://staging.example.com/webhooks/channex
# CHANNEX_WEBHOOK_SECRET=

# Sentry staging project
# SENTRY_DSN=https://...@sentry.io/...
# APP_RELEASE=git-sha-from-ci

# Email (Resend sandbox or verified staging domain)
# RESEND_API_KEY=re_...
# EMAIL_FROM_DEFAULT=noreply@staging.example.com

ALLOW_PUBLIC_REGISTRATION=false
REFRESH_COOKIE_SECURE=true

POSTGRES_USER=openpms
POSTGRES_PASSWORD=REPLACE_STRONG_PASSWORD
POSTGRES_DB=openpms
DATABASE_URL=postgresql+asyncpg://openpms:REPLACE_STRONG_PASSWORD@db:5432/openpms
CELERY_BROKER_URL=redis://redis:6379/0

# Backups (staging bucket)
# S3_BUCKET=openpms-staging-backups
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
