{
    # Let's Encrypt account email (required for public HTTPS).
    email {$ACME_EMAIL}
}

{$DOMAIN} {
    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Deep health probe hits DB+Redis — keep off the public edge (ops/VPN only).
    @deep path /health/deep
    respond @deep 403

    reverse_proxy api:8000
}
