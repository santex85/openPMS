POSTGRES_USER=openpms
POSTGRES_PASSWORD=openpms
POSTGRES_DB=openpms
POSTGRES_PORT=5432
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://openpms:openpms@localhost:5432/openpms
# Async SQLAlchemy pool (optional; defaults suit a single small property deployment)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=5
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800
# HS256 (default): must be >= 32 characters or the API exits at startup (app/core/config.py).
# Docker Compose reads this file for ${JWT_SECRET}; keep it long in dev copy-pastes.
JWT_SECRET=openpms-dev-hs256-secret-min-32-chars-change-me!!
# Local dev: allow POST /auth/register. Production: false + invite-only.
ALLOW_PUBLIC_REGISTRATION=true
# Production: prefer RS256 so verifiers only need the public key
# JWT_ALGORITHM=RS256
# PEM can use literal newlines or \n escapes in a single env value
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional: Fernet key (output of Fernet.generate_key() as ASCII) for encrypting webhook secrets at rest.
# If unset, encryption key is derived from JWT_SECRET (HS256). For RS256 production deploys, set this explicitly.
# When rotating: call POST /webhooks/subscriptions/reencrypt-secrets (owner JWT) with the new key, then set this env var to the same value and restart.
# WEBHOOK_SECRET_FERNET_KEY=

# Comma-separated origins for the Vite/React dev server (CORS). Used when the SPA runs on another port than the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HttpOnly refresh cookie: default is true (Secure). Use false only for local HTTP dev.
# only for local HTTP dev
REFRESH_COOKIE_SECURE=false

# Set to 1 for JSON logs (structlog) on stdout; default is human-readable key-value lines.
# LOG_JSON=
