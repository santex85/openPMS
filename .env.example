POSTGRES_USER=openpms
POSTGRES_PASSWORD=openpms
POSTGRES_DB=openpms
POSTGRES_PORT=5432
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://openpms:openpms@localhost:5432/openpms

# Celery broker (Redis). Local: match docker-compose redis port. In Compose stack use redis://redis:6379/0.
CELERY_BROKER_URL=redis://localhost:6379/0

# Channex: public URL of OpenPMS POST /webhooks/channex (e.g. https://api.example.com/webhooks/channex).
# Leave empty to skip webhook registration on activate (ARI sync still queues).
# CHANNEX_WEBHOOK_URL=
# Optional HMAC: raw body SHA256 hex vs header X-Channex-Signature (if Channex sends it).
# CHANNEX_WEBHOOK_SECRET=
# Production without secret: set true to allow only 34.76.12.0/24 (false for local dev).
# CHANNEX_WEBHOOK_VERIFY_CHANNEX_IPS=false
# Async SQLAlchemy pool (optional; defaults suit a single small property deployment)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=5
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800
# HS256 (default): must be >= 32 characters or the API exits at startup (app/core/config.py).
# Docker Compose reads this file for ${JWT_SECRET}; keep it long in dev copy-pastes.
JWT_SECRET=openpms-dev-hs256-secret-min-32-chars-change-me!!
# Local dev: allow POST /auth/register. Production: false + invite-only.
ALLOW_PUBLIC_REGISTRATION=true
# Production: prefer RS256 so verifiers only need the public key
# JWT_ALGORITHM=RS256
# PEM can use literal newlines or \n escapes in a single env value
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional: Fernet key (output of Fernet.generate_key() as ASCII) for encrypting webhook secrets at rest.
# If unset, encryption key is derived from JWT_SECRET (HS256). For RS256 production deploys, set this explicitly.
# When rotating: call POST /webhooks/subscriptions/reencrypt-secrets (owner JWT) with the new key, then set this env var to the same value and restart.
# WEBHOOK_SECRET_FERNET_KEY=
# Stripe Connect `stripe_account_id` at rest uses the same Fernet key as webhook secrets (`app.core.stripe_secrets`).
# Stripe Connect OAuth (Phase 2): register redirect URL in Stripe Dashboard to match STRIPE_REDIRECT_URI exactly.
# STRIPE_SECRET_KEY=
# STRIPE_CLIENT_ID=
# STRIPE_REDIRECT_URI=http://localhost:8000/stripe/oauth/callback
# Frontend URL after successful connect (302 redirect; ?property_id=...&connected=1 appended).
# STRIPE_CONNECT_SUCCESS_URL=http://localhost:5173/settings
# Optional HMAC key for OAuth state; if unset, HS256 uses JWT_SECRET, RS256 uses WEBHOOK_SECRET_FERNET_KEY.
# STRIPE_OAUTH_STATE_SECRET=

# Resend (transactional email). Leave RESEND_API_KEY empty for local dev without sending.
# RESEND_API_KEY=re_...
# EMAIL_FROM_DEFAULT=noreply@your-verified-domain.com

# Comma-separated origins for the Vite/React dev server (CORS). Used when the SPA runs on another port than the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HttpOnly refresh cookie: default is true (Secure). Use false only for local HTTP dev.
# only for local HTTP dev
REFRESH_COOKIE_SECURE=false

# Set to 1 for JSON logs (structlog) on stdout; default is human-readable key-value lines.
# LOG_JSON=
